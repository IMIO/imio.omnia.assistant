<?xml version="1.0"?>
<registry
    xmlns:i18n="http://xml.zope.org/namespaces/i18n"
    i18n:domain="imio.omnia.assistant">

  <records interface="imio.omnia.assistant.browser.controlpanel.IOmniaAssistantSettings"/>

  <!-- Assistant UI widget (self-contained, Preact bundled inside) -->
  <records prefix="plone.bundles/omnia-assistant"
           interface="Products.CMFPlone.interfaces.IBundleRegistry">
    <value key="jscompilation">++plone++imio.omnia.assistant/omnia-assistant-ui.js</value>
    <value key="csscompilation">++plone++imio.omnia.assistant/omnia-assistant-ui.css</value>
    <value key="enabled">True</value>
    <value key="compile">False</value>
  </records>

</registry>
