#: ../browser/controlpanel.py:131
msgid "AI Assistant settings"
msgstr "Paramètres de l'assistant IA"

#: ../browser/controlpanel.py:83
msgid "CSS selector to extract page content from."
msgstr "Sélecteur CSS pour extraire le contenu de la page."

#: ../browser/controlpanel.py:121
msgid "Disclaimer"
msgstr "Avertissement"

#: ../browser/controlpanel.py:122
msgid ""
"Disclaimer text shown at the bottom of the chat panel. Leave empty for the "
"default French disclaimer."
msgstr ""
"Texte d'avertissement affiché en bas du panneau de chat. Laisser vide pour "
"l'avertissement français par défaut."

#: ../browser/controlpanel.py:102
msgid "Display mode"
msgstr "Mode d'affichage"

#: ../browser/controlpanel.py:60
msgid "Enable or disable the AI assistant globally."
msgstr "Activer ou désactiver l'assistant IA globalement."

#: ../browser/controlpanel.py:59
msgid "Enabled"
msgstr "Activé"

#: ../browser/controlpanel.py:77
msgid "Include current page content as context for the AI."
msgstr "Inclure le contenu de la page actuelle comme contexte pour l'IA."

#: ../browser/controlpanel.py:76
msgid "Include page content"
msgstr "Inclure le contenu de la page"

#: ../browser/controlpanel.py:116
msgid "Initial panel height in pixels."
msgstr "Hauteur initiale du panneau en pixels."

#: ../browser/controlpanel.py:110
msgid "Initial panel width in pixels."
msgstr "Largeur initiale du panneau en pixels."

#: ../browser/controlpanel.py:96
msgid "Max context characters"
msgstr "Nombre maximum de caractères de contexte"

#: ../browser/controlpanel.py:97
msgid "Maximum characters of page content to include as context."
msgstr "Nombre maximum de caractères du contenu de la page à inclure comme contexte."

#: ../browser/controlpanel.py:102
msgid "Max messages per conversation"
msgstr "Nombre maximum de messages par conversation"

#: ../browser/controlpanel.py:103
msgid ""
"Maximum number of user messages allowed in a single conversation. "
"Set to 0 for no limit."
msgstr ""
"Nombre maximum de messages utilisateur autorisés dans une conversation. "
"Mettre à 0 pour ne pas limiter."

#: ../browser/controlpanel.py:65
msgid "Model"
msgstr "Modèle"

#: ../browser/controlpanel.py:66
msgid "Model for the OpenAI-compatible API."
msgstr "Modèle pour l'API compatible OpenAI."

#: ../browser/controlpanel.py:82
msgid "Page content CSS selector"
msgstr "Sélecteur CSS du contenu de la page"

#: ../browser/controlpanel.py:103
msgid "Panel display mode: floating (draggable) or fixed."
msgstr "Mode d'affichage du panneau : flottant (déplaçable) ou fixe."

#: ../browser/controlpanel.py:115
msgid "Panel height"
msgstr "Hauteur du panneau"

#: ../browser/controlpanel.py:109
msgid "Panel width"
msgstr "Largeur du panneau"

#: ../browser/controlpanel.py:71
msgid "System prompt"
msgstr "Prompt système"

#: ../browser/controlpanel.py:72
msgid "System prompt sent with every conversation."
msgstr "Prompt système envoyé avec chaque conversation."

#: ../browser/controlpanel.py:89
msgid "Use innerText instead of innerHTML for page content extraction."
msgstr "Utiliser innerText au lieu de innerHTML pour l'extraction du contenu de la page."

#: ../browser/controlpanel.py:88
msgid "Use plain text"
msgstr "Utiliser le texte brut"
