<configure
  xmlns="http://namespaces.zope.org/zope"
  xmlns:browser="http://namespaces.zope.org/browser"
  xmlns:plone="http://namespaces.plone.org/plone"
  i18n_domain="imio.omnia.assistant">

  <!-- Set overrides folder for Just-a-Bunch-Of-Templates product -->
  <include package="z3c.jbot" file="meta.zcml"/>
  <browser:jbot
    directory="overrides"
    layer="imio.omnia.assistant.interfaces.IImioOmniaAssistantLayer"
  />

  <!-- Publish static files -->
  <plone:static
    name="imio.omnia.assistant"
    type="plone"
    directory="static"
  />

  <!-- Vocabulary: available models from the OpenAI-compatible API -->
  <utility
    factory=".controlpanel.OmniaModelsVocabularyFactory"
    provides="zope.schema.interfaces.IVocabularyFactory"
    name="imio.omnia.assistant.models"
  />

  <browser:page
    name="omnia-assistant-settings"
    for="Products.CMFPlone.interfaces.IPloneSiteRoot"
    class=".controlpanel.OmniaAssistantControlPanelView"
    permission="cmf.ManagePortal"
    layer="imio.omnia.assistant.interfaces.IImioOmniaAssistantLayer"
  />

  <browser:page
    name="omnia-assistant-api"
    for="*"
    class=".proxy.OmniaAssistantOpenAIProxyView"
    permission="imio.omnia.core.AccessOmniaOpenAIProxy"
    layer="imio.omnia.assistant.interfaces.IImioOmniaAssistantLayer"
  />

  <!-- Viewlet: inject window.omnia_assistant_settings and mount the chat widget -->
  <browser:viewlet
    name="omnia-assistant-config"
    for="*"
    manager="plone.app.layout.viewlets.interfaces.IHtmlHead"
    class=".viewlets.OmniaAssistantConfigViewlet"
    template="templates/omnia_assistant_config.pt"
    permission="zope2.View"
    layer="imio.omnia.assistant.interfaces.IImioOmniaAssistantLayer"
  />


</configure>
